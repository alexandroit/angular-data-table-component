{
  "name": "@stackline/angular-data-table-component",
  "version": "21.0.0",
  "description": "A maintained Angular 21 data table component with sorting, selection, expandable rows, pagination, and versioned docs.",
  "keywords": [
    "angular",
    "angular15",
    "angular16",
    "angular17",
    "angular18",
    "angular19",
    "angular20",
    "angular21",
    "angular-library",
    "typescript",
    "data-table",
    "datatable",
    "table",
    "grid",
    "sorting",
    "pagination",
    "selectable-rows",
    "expandable-rows",
    "conditional-styles",
    "responsive",
    "ui-component",
    "component-library",
    "maintained",
    "maintained"
  ],
  "homepage": "https://alexandroit.github.io/angular-data-table-component/",
  "bugs": {
    "url": "https://github.com/alexandroit/angular-data-table-component/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/alexandroit/angular-data-table-component.git"
  },
  "license": "MIT",
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "sideEffects": false,
  "main": "./dist/fesm2022/stackline-angular-data-table-component.mjs",
  "module": "./dist/fesm2022/stackline-angular-data-table-component.mjs",
  "es2022": "./dist/fesm2022/stackline-angular-data-table-component.mjs",
  "fesm2022": "./dist/fesm2022/stackline-angular-data-table-component.mjs",
  "typings": "./dist/types/stackline-angular-data-table-component.d.ts",
  "types": "./dist/types/stackline-angular-data-table-component.d.ts",
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "ng-packagr -p ng-package.json",
    "docs:install:angular-15": "cd docs-src/angular-15 && npm install --ignore-scripts",
    "build:docs:angular-15": "cd docs-src/angular-15 && npm run build",
    "docs:install:angular-16": "cd docs-src/angular-16 && npm install --ignore-scripts",
    "build:docs:angular-16": "cd docs-src/angular-16 && npm run build",
    "docs:install:angular-17": "cd docs-src/angular-17 && npm install --ignore-scripts",
    "build:docs:angular-17": "cd docs-src/angular-17 && npm run build",
    "docs:install:angular-18": "cd docs-src/angular-18 && npm install --ignore-scripts",
    "build:docs:angular-18": "cd docs-src/angular-18 && npm run build",
    "docs:install:angular-19": "cd docs-src/angular-19 && npm install --ignore-scripts",
    "build:docs:angular-19": "cd docs-src/angular-19 && npm run build",
    "docs:install:angular-20": "cd docs-src/angular-20 && npm install --ignore-scripts",
    "build:docs:angular-20": "cd docs-src/angular-20 && npm run build",
    "docs:install:angular-21": "cd docs-src/angular-21 && npm install --ignore-scripts",
    "build:docs:angular-21": "cd docs-src/angular-21 && npm run build",
    "build:docs": "npm run build:docs:angular-21"
  },
  "peerDependencies": {
    "@angular/common": ">=21.0.0 <22.0.0",
    "@angular/core": ">=21.0.0 <22.0.0"
  },
  "dependencies": {
    "tslib": "^2.3.0"
  },
  "devDependencies": {
    "@angular/common": "21.2.7",
    "@angular/compiler": "21.2.7",
    "@angular/compiler-cli": "21.2.7",
    "@angular/core": "21.2.7",
    "ng-packagr": "21.2.2",
    "typescript": "~5.9.3"
  }
}
