{
  "name": "@revivejs/angular-data-table-component",
  "version": "17.0.0",
  "description": "A maintained Angular 17 data table component with sorting, selection, expandable rows, pagination, and versioned docs.",
  "keywords": [
    "angular",
    "angular15",
    "angular16",
    "angular17",
    "angular-library",
    "typescript",
    "data-table",
    "datatable",
    "table",
    "grid",
    "sorting",
    "pagination",
    "selectable-rows",
    "expandable-rows",
    "conditional-styles",
    "responsive",
    "ui-component",
    "component-library",
    "revived",
    "maintained",
    "revivejs"
  ],
  "homepage": "https://alexandroit.github.io/angular-data-table-component/",
  "bugs": {
    "url": "https://github.com/alexandroit/angular-data-table-component/issues"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/alexandroit/angular-data-table-component.git"
  },
  "license": "MIT",
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "sideEffects": false,
  "main": "./dist/fesm2022/revivejs-angular-data-table-component.mjs",
  "module": "./dist/fesm2022/revivejs-angular-data-table-component.mjs",
  "es2022": "./dist/fesm2022/revivejs-angular-data-table-component.mjs",
  "esm2022": "./dist/esm2022/revivejs-angular-data-table-component.mjs",
  "fesm2022": "./dist/fesm2022/revivejs-angular-data-table-component.mjs",
  "typings": "./dist/index.d.ts",
  "types": "./dist/index.d.ts",
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "ng-packagr -p ng-package.json",
    "docs:install:angular-15": "cd docs-src/angular-15 && npm install --ignore-scripts",
    "build:docs:angular-15": "cd docs-src/angular-15 && npm run build",
    "docs:install:angular-16": "cd docs-src/angular-16 && npm install --ignore-scripts",
    "build:docs:angular-16": "cd docs-src/angular-16 && npm run build",
    "docs:install:angular-17": "cd docs-src/angular-17 && npm install --ignore-scripts",
    "build:docs:angular-17": "cd docs-src/angular-17 && npm run build",
    "build:docs": "npm run build:docs:angular-17"
  },
  "peerDependencies": {
    "@angular/common": ">=15.0.0 <18.0.0",
    "@angular/core": ">=15.0.0 <18.0.0"
  },
  "dependencies": {
    "tslib": "^2.3.0"
  },
  "devDependencies": {
    "@angular/common": "17.3.12",
    "@angular/compiler": "17.3.12",
    "@angular/compiler-cli": "17.3.12",
    "@angular/core": "17.3.12",
    "ng-packagr": "17.3.0",
    "typescript": "~5.4.5"
  }
}
