{
  "compilerOptions": {
    "baseUrl": ".",
    "declaration": true,
    "declarationMap": true,
    "downlevelIteration": true,
    "experimentalDecorators": true,
    "importHelpers": true,
    "inlineSources": true,
    "lib": [
      "dom",
      "es2022"
    ],
    "module": "es2020",
    "moduleResolution": "node",
    "outDir": "./dist/out-tsc",
    "sourceMap": true,
    "target": "es2020",
    "types": []
  },
  "angularCompilerOptions": {
    "compilationMode": "full",
    "strictInjectionParameters": false,
    "strictInputAccessModifiers": false,
    "strictTemplates": false
  },
  "exclude": [
    "dist",
    "docs",
    "docs-src",
    "**/*.spec.ts"
  ]
}
